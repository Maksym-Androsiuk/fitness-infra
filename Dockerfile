# Використовуємо офіційний образ як базу
FROM wger/server:latest

# Встановлюємо додаткові залежності для тестування всередині контейнера (якщо потрібно)
RUN pip install pytest requests

# Копіюємо локальний код (якщо є кастомізації)
COPY . /app
WORKDIR /app

# Відкриваємо порт
EXPOSE 8000

# Команда запуску (використовуємо dev сервер для спрощення, у прод - gunicorn)
CMD ["python3", "manage.py", "runserver", "0.0.0.0:8000"]